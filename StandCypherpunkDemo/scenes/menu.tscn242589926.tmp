[sub_resource type="GDScript" id="GDScript_5qq6a"]
script/source = "extends Node

func _ready():
	var theme = Theme.new()

	# Cor da sombra
	theme.set_color(\"font_shadow_color\", \"Button\", Color(0.012, 0.718, 0.729, 1.0))

	# Offset (igual ao Figma)
	theme.set_constant(\"shadow_offset_x\", \"Button\", 0)
	theme.set_constant(\"shadow_offset_y\", \"Button\", 6)

	# \"Blur\" da sombra (o mais próximo no Godot)
	theme.set_constant(\"shadow_outline_size\", \"Button\", 2)

	get_tree().root.theme = theme
"

